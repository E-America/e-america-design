                      "y": 0.6939335546604231
                    }
                  },
                  "textGrowth": "fixed-width-height",
                  "width": "fill_container",
                  "height": 100,
                  "content": "A Digital Experiment in Governance",
                  "lineHeight": 0.6,
                  "textAlign": "center",
                  "textAlignVertical": "middle",
                  "fontFamily": "Ubuntu",
                  "fontSize": 40,
                  "fontWeight": "700",
                  "letterSpacing": 2
                }
              ]
            },
            {
              "type": "frame",
              "id": "BhTKw",
              "name": "Frame 27",
              "width": "fill_container",
              "stroke": {
                "align": "inside",
                "thickness": {
                  "top": 1
                },
                "fill": "#769dd1ff"
              },
              "layout": "vertical",
              "children": [
                {
                  "type": "frame",
                  "id": "jJiwU",
                  "name": "Frame 23",
                  "width": "fill_container",
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "gap": 67,
                  "justifyContent": "end",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "OBwFh",
                      "name": "There is America the physical place. And there is America the idea, the idea of free people. e-America is that idea, reborn for the digital age. e-America is a parallel digital America, an experiment in building government as a service for a borderless digital world. It is not a replacement for any existing nation. It is a parallel, digital America built on values, not geography, open to anyone who believes in liberty, equality, and the rule of law.",
                      "fill": "#0b1e46ff",
                      "textGrowth": "fixed-width",
                      "width": 725,
                      "content": "There is America the physical place. And there is America the idea, the idea of free people that sparked America's entrepreneurial spirit. e-America is that idea and spirit of innovation reborn as a borderless digital nation.\n\ne-America is a parallel digital America, an experiment in building government as a service for a borderless digital world. It is not a replacement for any existing nation. It brings America's entrepreneurial and innovative spirit into the cloud, a parallel digital America built on values, not geography, open to builders and entrepreneurs everywhere who believe in liberty, equality, and the rule of law.",
                      "lineHeight": 1.5454545454545454,
                      "textAlignVertical": "middle",
                      "fontFamily": "Ubuntu",
                      "fontSize": 22,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "rectangle",
                      "id": "eWWs4",
                      "name": "Rectangle 4",
                      "fill": {
                        "type": "image",
                        "enabled": true,
                        "url": "./assets/digital-experiment-1.png",
                        "mode": "fill"
                      },
                      "width": 868.0260009765625,
                      "height": 473.74658203125,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1
                      }
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "C4h5M",
                  "name": "Frame 24",
                  "width": "fill_container",
                  "height": 465,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "gap": 146,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "rectangle",
                      "id": "SNf29",
                      "name": "Rectangle 5",
                      "fill": {
                        "type": "image",
                        "enabled": true,
                        "url": "./assets/digital-experiment-2.png",
                        "mode": "fill"
                      },
                      "width": 868.7138671875,
                      "height": 474.12200927734375,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1
                      }
                    },
                    {
                      "type": "text",
                      "id": "sfGQW",
                      "name": "By joining, you agree to uphold the American Constitution, the timeless framework that has guided one of history’s most enduring democracies. Once you join, you become an e-American and receive your digital passport, your identity in a global community united by shared principles, powered by Bitcoin.",
                      "fill": "#0b1e46ff",
                      "textGrowth": "fixed-width",
                      "width": 604,
                      "content": "By joining, you agree to uphold the American Constitution, the timeless framework that helped build one of the most innovative societies in history.\n\nOnce you join, you become an e-American and receive your digital passport, your identity in a global community of builders and entrepreneurs united by shared principles, powered by Bitcoin.",
                      "lineHeight": 1.5454545454545454,
                      "textAlignVertical": "middle",
                      "fontFamily": "Ubuntu",
                      "fontSize": 22,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
