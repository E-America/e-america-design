                },
                {
                  "type": "text",
                  "id": "u4r9J",
                  "name": "A Digital Experiment in Freedom",
                  "fill": {
                    "type": "gradient",
                    "gradientType": "linear",
                    "enabled": true,
                    "rotation": -445.6571491675639,
                    "size": {
                      "height": 0.6800453507719172
