                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "4gWBD",
                          "name": "e-Treasury",
                          "fill": "#b30c2aff",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "e-Treasury",
                          "lineHeight": 1.4166666666666667,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 24,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "NwYGN",
                          "name": "The e-America Treasury will operate entirely in Bitcoin, held transparently and governed by multi signature wallets.",
                          "fill": "#0b1e46ff",
                          "textGrowth": "fixed-width",
                          "width": 504,
                          "content": "The e-America Treasury will operate entirely in Bitcoin. The Bitcoin Treasury is live and viewable by e-Americans in the Citizen Dashboard.",
                          "lineHeight": 1.7,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 20,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "h94AF",
                      "name": "Frame 14",
                      "width": "fill_container",
                      "stroke": {
                        "align": "inside",
                        "thickness": 1
                      },
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "rY9l3",
                          "name": "Citizen Wallets",
                          "fill": "#b30c2aff",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Citizen Wallets",
                          "lineHeight": 1.4166666666666667,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 24,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "2IC9E",
                          "name": "Each e-American will have a verified wallet to receive, transact, and participate in treasury governance.",
                          "fill": "#0b1e46ff",
                          "textGrowth": "fixed-width",
                          "width": 501.5436096191406,
                          "content": "Each e-American will have a verified wallet to receive, transact, and participate in treasury governance.",
                          "lineHeight": 1.7,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 20,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "Ypujc",
                      "name": "Frame 15",
                      "width": "fill_container",
                      "stroke": {
                        "align": "inside",
                        "thickness": 1
                      },
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "cf8Y6",
                          "name": "Why Bitcoin?",
                          "fill": "#b30c2aff",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Why Bitcoin?",
                          "lineHeight": 1.4166666666666667,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 24,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "xWOod",
                          "name": "Bitcoin is the official currency and financial foundation of e-America. It ensures that the digital nation remains neutral, global, and incorruptible.",
                          "fill": "#0b1e46ff",
                          "textGrowth": "fixed-width",
                          "width": 501.5436096191406,
                          "content": "Bitcoin is the official currency and financial foundation of e-America. It ensures that the digital nation remains neutral, global, and incorruptible.",
                          "lineHeight": 1.7,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 20,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8Y5lh",
                          "name": "Economic independence where no central authority controls it Transparency where every transaction is verifiable Borderless inclusion where anyone can participate",
                          "fill": "#0b1e46ff",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "• Economic independence where no central authority controls it\n• Transparency where every transaction is verifiable\n• Borderless inclusion where anyone can participate",
                          "lineHeight": 1.7,
                          "textAlignVertical": "middle",
                          "fontFamily": "Ubuntu",
                          "fontSize": 20,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
